# Redis (host default — docker-compose overrides to redis://redis:6379/0 inside network)
REDIS_URL=redis://localhost:5001/0
# Required. Generate with: openssl rand -hex 32
REDIS_PASSWORD=

# FastAPI bind
API_HOST=0.0.0.0
API_PORT=5000

# TTLs / queue sizing
PAYLOAD_TTL_SECONDS=86400
STREAM_MAXLEN=1000000
STREAM_KEY=wh:stream
DEAD_STREAM_KEY=wh:dead
CONSUMER_GROUP=workers
MAX_DELIVERIES=5

# Reject any POST larger than this (bytes). 1 MiB default.
MAX_BODY_BYTES=1048576

# Ruckus One sends this verbatim in the Authorization header (with or without 'Bearer ' prefix).
RUCKUS_ONE_WEBHOOK_SECRET=

# CSV of /webhook/<source> path names that this receiver accepts.
# Whatever URL ID you typed into the Ruckus webhook config goes here.
# Anything else returns 404.
# Examples: "ruckus", "testingdnd", "ruckus,testingdnd,tenant42"
RUCKUS_ONE_SOURCE_NAMES=ruckus

# Cloudflare named-tunnel token. Treat like a password.
TUNNEL_TOKEN=
